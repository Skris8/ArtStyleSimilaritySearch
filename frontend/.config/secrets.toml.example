# Copia este archivo a frontend/.config/secrets.toml y rellena los valores reales.
# Qdrant (preferible)
qdrant_db_url = "https://your-qdrant-host"
qdrant_api_key = "YOUR_QDRANT_API_KEY"

# MySQL (opcional - para login admin)
mysql_host = "127.0.0.1"
mysql_port = 3306
mysql_user = "db_user"
mysql_password = "db_pass"
mysql_database = "db_name"

# Alternativamente exporta variables de entorno: QDRANT_URL, QDRANT_API_KEY, MYSQL_*
